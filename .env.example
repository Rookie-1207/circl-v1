# ── Required ──────────────────────────────────────────────────────────────────

# Port the API server binds to
PORT=8080

# PostgreSQL connection string
DATABASE_URL=postgresql://user:password@localhost:5432/circl

# Supabase project URL (e.g. https://xxxx.supabase.co)
SUPABASE_URL=https://your-project.supabase.co

# Supabase JWT secret (Settings → API → JWT Secret in the Supabase dashboard)
SUPABASE_JWT_SECRET=your-supabase-jwt-secret

# ── Optional — Security ───────────────────────────────────────────────────────

# Comma-separated list of allowed CORS origins in production.
# Example: https://circl.app,https://www.circl.app
# When absent (or in development) all origins are allowed.
CORS_ORIGIN=

# ── Optional — Monitoring (leave empty to disable) ────────────────────────────

# Sentry — https://docs.sentry.io/platforms/node/
SENTRY_DSN=

# PostHog — https://posthog.com/docs/libraries/node
POSTHOG_API_KEY=
POSTHOG_HOST=https://app.posthog.com

# Better Stack — https://betterstack.com/docs/logs/
# Requires: pnpm --filter @workspace/api-server add @logtail/pino
BETTERSTACK_TOKEN=

# ── Optional — JWT overrides ──────────────────────────────────────────────────

# Override JWT issuer (defaults to ${SUPABASE_URL}/auth/v1)
SUPABASE_JWT_ISSUER=

# Override JWT audience (defaults to "authenticated")
SUPABASE_JWT_AUDIENCE=
